# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
SUPABASE_URL=https:<your-supabase-url>
# Use the "service_role" key for server-side (has full DB access, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
# ─── Twilio WhatsApp ──────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
# For Twilio Sandbox: whatsapp:+14155238886
# For production (approved number): whatsapp:+91XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Admin Authentication ─────────────────────────────────────────────────────
# These are the doctor/staff login credentials for /admin
ADMIN_EMAIL=doctor@noahclinic.com
ADMIN_PASSWORD=YourSecurePassword123!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your-random-256bit-secret-here

# ─── Email Fallback (Nodemailer via Gmail) ────────────────────────────────────
# Use a Gmail account + App Password (NOT your real password)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-clinic-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
CLINIC_EMAIL=doctor@noahclinic.com

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://noah-animal-clinic.vercel.app/

# ─── Google Calendar Integration ─────────────────────────────────────────────
# Automatically adds confirmed appointments to the doctor's Google Calendar.
#
# Setup steps:
#  1. Go to https://console.cloud.google.com → Create / select a project
#  2. Enable "Google Calendar API"
#  3. IAM & Admin → Service Accounts → Create Service Account → Create JSON key
#  4. Share the doctor's Google Calendar with the service account email
#     (Calendar Settings → Share with specific people → Add service account email → "Make changes to events")
#  5. Set the three vars below:
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the downloaded JSON key file.
# In Vercel, paste it exactly as-is (with real newlines). Locally use \n escapes.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# The doctor's calendar ID – usually their Gmail address, e.g. doctor@gmail.com
GOOGLE_CALENDAR_ID=doctor@gmail.com
